# =============================================================================
# ta3lem — Production Environment Configuration
# =============================================================================
# Copy this file to .env and fill in all values.
# Run `node scripts/generate-secrets.js` to generate JWT secrets.
# =============================================================================

# ─────────────────────────────────────────────────────────────────────────────
# App
# ─────────────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=4000
APP_NAME=ta3lem
APP_URL=https://ta3lem.example.com
CLIENT_URL=https://ta3lem.example.com
API_PREFIX=/api/v1

# ─────────────────────────────────────────────────────────────────────────────
# Database (MySQL)
# ─────────────────────────────────────────────────────────────────────────────
DB_HOST=mysql
DB_PORT=3306
DB_NAME=ta3lem
DB_USER=ta3lem
DB_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
DB_POOL_MIN=5
DB_POOL_MAX=50
DB_LOGGING=false

# ─────────────────────────────────────────────────────────────────────────────
# Redis (cache + queue)
# ─────────────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
REDIS_DB=0

# ─────────────────────────────────────────────────────────────────────────────
# JWT — Run `node scripts/generate-secrets.js` to generate strong secrets
# ─────────────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=CHANGE_ME_RUN_generate_secrets_js
JWT_REFRESH_SECRET=CHANGE_ME_RUN_generate_secrets_js
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
JWT_ISSUER=ta3lem

# ─────────────────────────────────────────────────────────────────────────────
# Security
# ─────────────────────────────────────────────────────────────────────────────
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300

# ─────────────────────────────────────────────────────────────────────────────
# File storage
# ─────────────────────────────────────────────────────────────────────────────
UPLOAD_DIR=/app/storage/uploads
RECORDING_DIR=/app/storage/recordings
MAX_UPLOAD_MB=200

# ─────────────────────────────────────────────────────────────────────────────
# Live streaming provider: livekit | agora
# ─────────────────────────────────────────────────────────────────────────────
LIVE_PROVIDER=livekit
LIVEKIT_HOST=http://livekit:7880
LIVEKIT_API_KEY=CHANGE_ME_LIVEKIT_KEY
LIVEKIT_API_SECRET=CHANGE_ME_LIVEKIT_SECRET
AGORA_APP_ID=
AGORA_APP_CERTIFICATE=

# ─────────────────────────────────────────────────────────────────────────────
# WhatsApp (Baileys session stored in /app/storage/wa-session)
# ─────────────────────────────────────────────────────────────────────────────
WA_ENABLED=true
WA_SESSION_DIR=/app/storage/wa-session
WA_GROUP_NOTIFY=true

# ─────────────────────────────────────────────────────────────────────────────
# SMTP (Email)
# ─────────────────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=CHANGE_ME_SMTP_USER
SMTP_PASS=CHANGE_ME_SMTP_PASS
SMTP_FROM=noreply@ta3lem.app

# ─────────────────────────────────────────────────────────────────────────────
# AI (OpenAI or Gemini)
# ─────────────────────────────────────────────────────────────────────────────
AI_PROVIDER=openai
OPENAI_API_KEY=sk-CHANGE_ME_YOUR_OPENAI_KEY
GEMINI_API_KEY=CHANGE_ME_YOUR_GEMINI_KEY

# ─────────────────────────────────────────────────────────────────────────────
# Logging
# ─────────────────────────────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_TO_FILE=true

# ─────────────────────────────────────────────────────────────────────────────
# MySQL root password (used by docker-compose mysql service)
# ─────────────────────────────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=CHANGE_ME_ROOT_PASSWORD
