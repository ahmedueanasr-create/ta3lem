# ─────────────────────────────────────────────────────────────
# App
# ─────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
APP_NAME=ta3lem
APP_URL=http://localhost:4000
CLIENT_URL=http://localhost:3000
API_PREFIX=/api/v1

# ─────────────────────────────────────────────────────────────
# Database (MySQL)
# ─────────────────────────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=ta3lem
DB_USER=root
DB_PASSWORD=
DB_POOL_MIN=5
DB_POOL_MAX=50
DB_LOGGING=false

# ─────────────────────────────────────────────────────────────
# Redis (cache + queue)
# ─────────────────────────────────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ─────────────────────────────────────────────────────────────
# JWT
# ─────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
JWT_ISSUER=ta3lem

# ─────────────────────────────────────────────────────────────
# Security
# ─────────────────────────────────────────────────────────────
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300

# ─────────────────────────────────────────────────────────────
# File storage
# ─────────────────────────────────────────────────────────────
UPLOAD_DIR=storage/uploads
RECORDING_DIR=storage/recordings
MAX_UPLOAD_MB=200

# ─────────────────────────────────────────────────────────────
# Live streaming provider: livekit | agora
# ─────────────────────────────────────────────────────────────
LIVE_PROVIDER=livekit
LIVEKIT_HOST=http://127.0.0.1:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret
AGORA_APP_ID=
AGORA_APP_CERTIFICATE=

# ─────────────────────────────────────────────────────────────
# WhatsApp (Baileys session stored in storage/wa-session)
# ─────────────────────────────────────────────────────────────
WA_ENABLED=true
WA_SESSION_DIR=storage/wa-session
WA_GROUP_NOTIFY=true

# ─────────────────────────────────────────────────────────────
# Logging
# ─────────────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_TO_FILE=true
